# ==============================================================================
# Tally MIS Automation Dashboard - Git Ignore Rules
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Specific & Temp Uploads
# ------------------------------------------------------------------------------
# Ignore raw trial balance uploads and generated monthly workbooks
uploads/
backend/uploads/
workbooks/
backend/workbooks/

# Temporary scratchpad for debugging scripts and outputs
scratch/

# Ignore user Excel data exports / temp lock files
*.xlsx
!templates/*.xlsx
~$*.xlsx
~*

# ------------------------------------------------------------------------------
# Node / Frontend (React + Vite)
# ------------------------------------------------------------------------------
node_modules/
frontend/node_modules/
dist/
frontend/dist/
dist-ssr/
frontend/dist-ssr/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# Python / Backend (FastAPI)
# ------------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
backend/__pycache__/
backend/*/__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
.venv/
venv/
env/
ENV/
backend/.venv/
backend/venv/
backend/env/

# Distribution / packaging
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ------------------------------------------------------------------------------
# IDEs, Editors & OS Junk
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Environment Configurations (Secrets)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/*.local
backend/*.local

# ------------------------------------------------------------------------------
# Agent Configurations
# ------------------------------------------------------------------------------
.agent/